{
  "partners": {
    "partner_a": {
      "name": "Partner A",
      "label": "A"
    },
    "partner_b": {
      "name": "Partner B",
      "label": "B"
    }
  },
  "income": {
    "partner_a_net": 10000,
    "partner_b_net": 10000,
    "_comment": "Used for income_ratio / blended category share formulas. Contribution inflows are tracked separately, not as expenses."
  },
  "categories": {
    "kids": { "label": "Kids", "icon": "👧", "share_formula": "fixed", "share": { "partner_a": 0.5, "partner_b": 0.5 } },
    "food": {
      "label": "Food",
      "icon": "🛒",
      "share_formula": "fixed",
      "share": { "partner_a": 0.5, "partner_b": 0.5 }
    },
    "health": {
      "label": "Health",
      "icon": "💊",
      "share_formula": "blended",
      "share_blended_fixed_base": 0.25,
      "share_blended_variable_weight": 0.5
    },
    "house": {
      "label": "House",
      "icon": "🏠",
      "share_formula": "fixed",
      "share": { "partner_a": 0.5, "partner_b": 0.5 }
    },
    "equal": {
      "label": "Equal share",
      "icon": "⚖️",
      "share_formula": "fixed",
      "share": { "partner_a": 0.5, "partner_b": 0.5 }
    },
    "contribution": {
      "label": "Contribution",
      "icon": "💸",
      "share_formula": "fixed",
      "share": { "partner_a": 0.5, "partner_b": 0.5 },
      "_note": "Partner fund transfers into joint account. Excluded from spending charts; tracked separately in monthly compensation."
    },
    "other": {
      "label": "Other / unclassified",
      "icon": "❓",
      "share_formula": "fixed",
      "share": { "partner_a": 0.5, "partner_b": 0.5 }
    }
  },
  "classification_rules": {
    "kids": { "keywords": ["example_kids_store"], "case_sensitive": false },
    "food": { "keywords": ["example_supermarket"], "case_sensitive": false },
    "house": { "keywords": ["example_utility"], "case_sensitive": false },
    "health": { "keywords": ["example_health_store"], "case_sensitive": false },
    "equal": { "keywords": ["example_equal_split_merchant"], "case_sensitive": false },
    "contribution": {
      "_comment": "Two match strategies (both set category=contribution). 1) description_keywords: positive-amount transactions whose description contains the keyword; partner is explicit. 2) trigger_keywords + partner name + round amount: description contains a trigger keyword AND a partner name AND amount is a round multiple of round_number_multiple.",
      "description_keywords": [
        { "keyword": "top-up by *xxxx", "partner": "partner_a", "_note": "top-up from partner_a's card ending xxxx" }
      ],
      "trigger_keywords": ["traspaso", "transfer"],
      "round_number_multiple": 100,
      "case_sensitive": false
    }
  },
  "accounts": {
    "caixabank_common": {
      "label": "CaixaBank shared",
      "type": "shared",
      "parser": "caixabank"
    },
    "revolut_joint": {
      "label": "Revolut joint",
      "type": "shared",
      "parser": "revolut"
    },
    "caixabank_personal": {
      "label": "CaixaBank Personal",
      "type": "personal",
      "owner": "partner_a",
      "parser": "caixabank"
    }
  },
  "bank_imports": {
    "base_directory": "",
    "sources": [
      {
        "id": "caixabank_joint",
        "account_key": "caixabank_common",
        "file": "tmp/input/your_export.xls",
        "parser": "caixabank",
        "layout": {
          "sheet_index": 0,
          "transaction_date_column": "f_valor"
        }
      },
      {
        "id": "revolut_joint",
        "account_key": "revolut_joint",
        "file": "tmp/input/your_export.csv",
        "parser": "revolut",
        "layout": { "type": "revolut_csv", "state_filter": "COMPLETED" }
      },
      {
        "id": "caixabank_personal",
        "account_key": "caixabank_personal",
        "file": "tmp/input/your_personal_export.xls",
        "parser": "caixabank",
        "layout": {
          "sheet_index": 0,
          "transaction_date_column": "f_valor"
        }
      }
    ]
  },
  "personal_classification_rules": {
    "kids": {
      "keywords": [],
      "case_sensitive": false
    },
    "food": {
      "keywords": ["example_cafeteria", "example_restaurant"],
      "case_sensitive": false
    },
    "health": {
      "keywords": ["example_pharmacy"],
      "case_sensitive": false
    },
    "house": {
      "keywords": ["example_community_fees", "example_mortgage", "example_insurance"],
      "case_sensitive": false
    },
    "equal": {
      "keywords": ["example_saas_subscription", "example_travel", "example_transport"],
      "case_sensitive": false
    }
  }
}
